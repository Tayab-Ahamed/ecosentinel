# Backend Environment Variables (copy to .env and fill your keys)
# Required for full features
GEMINI_API_KEY=your_gemini_api_key_here
FIRMS_API_KEY=your_nasa_firms_api_key_here  # Required for fires

# Optional
OPENAQ_API_KEY=your_openaq_key_here
OPENWEATHER_API_KEY=

# Deployment/Dev
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ecosentinel
FRONTEND_URL=http://localhost:3000
ECOSENTINEL_BACKEND_URL=http://localhost:8000  # Voice agent
ECOSENTINEL_ENV=development  # production on deploy
ECOSENTINEL_SKIP_WHISPER_INIT=  # Set 1 to skip heavy Whisper load
LIVE_FEED_CITY=Bengaluru
LIVE_FEED_LAT=12.9716
LIVE_FEED_LON=77.5946

