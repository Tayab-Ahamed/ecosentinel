# Copy to .env and fill in real keys. Never commit .env.

GEMINI_API_KEY=your_gemini_api_key_here
OPENAQ_API_KEY=your_openaq_api_key_here
FIRMS_API_KEY=your_firms_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Public URL of this API (voice agent calls back into these routes). Use your deployed URL in production.
ECOSENTINEL_BACKEND_URL=http://localhost:8000

# Allowed CORS origin for your deployed frontend (in addition to built-in localhost / Vercel defaults).
FRONTEND_URL=http://localhost:3000

# production | prod — hides raw exception text from API clients; set in Railway/Docker.
# ECOSENTINEL_ENV=production

# Skip loading the Whisper model at startup (faster tests/CI; disables local STT until restart without this).
# ECOSENTINEL_SKIP_WHISPER_INIT=1

LIVE_FEED_CITY=Bengaluru
LIVE_FEED_LAT=12.9716
LIVE_FEED_LON=77.5946
